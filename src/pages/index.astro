---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SkillCategory from "../components/SkillCategory.astro";
import SkillItem from "../components/SkillItem.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ProjectSlider from "../components/ProjectSlider.astro";

const projects = [
  {
    title: "Maywa-Textil",
    language: "PHP",
    url: "https://github.com/Sebastian-RivMor/Maywa-Textil",
  },
  {
    title: "Control-de-inventario",
    language: "Python",
    url: "https://github.com/Sebastian-RivMor/Control-de-inventario",
  },
  {
    title: "Tragamonedas_Previa",
    language: "Python",
    url: "https://github.com/Sebastian-RivMor/Tragamonedas_Previa",
  },
  {
    title: "Mano-Robot-PY_ARD",
    language: "Python",
    url: "https://github.com/Sebastian-RivMor/Mano-Robot-PY_ARD",
  },
];
---

<Layout title="Sebastian Rivera">
  <Navbar />

  <main class="flex-grow">
    <!-- Hero Section -->
    <section
      class="min-h-[80vh] flex flex-col justify-center items-center text-center px-4 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-blue-gloomy/30 to-black-deep -z-10"
      >
      </div>
      <div
        class="w-32 h-32 md:w-48 md:h-48 rounded-full overflow-hidden border-4 border-cyan-electric shadow-[0_0_20px_rgba(0,210,225,0.3)] mb-8"
      >
        <img
          src="/images/perfil.webp"
          alt="Sebastián"
          class="w-full h-full object-cover"
        />
      </div>
      <h1 class="text-5xl md:text-7xl font-bold mb-4 tracking-tight">
        <span
          class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-electric to-orange-fire"
        >
          Sebastian Rivera
        </span>
      </h1>
      <div
        class="text-xl md:text-2xl text-gray-400 max-w-2xl mb-8 flex space-x-6"
      >
        <a
          href="https://github.com/Sebastian-RivMor"
          target="_blank"
          class="group flex items-center justify-center w-14 h-14 bg-white rounded-full shadow-lg transition-all duration-300 hover:bg-gray-900 hover:-translate-y-1"
        >
          <svg
            class="w-7 h-7 fill-gray-900 group-hover:fill-white transition-colors duration-300"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12"
            ></path>
          </svg>
        </a>

        <a
          href="https://www.linkedin.com/in/gustavo-sebastian-rivera-moreno-ab6928255"
          target="_blank"
          class="group flex items-center justify-center w-14 h-14 bg-white rounded-full shadow-lg transition-all duration-300 hover:bg-[#0077b5] hover:-translate-y-1"
        >
          <svg
            class="w-6 h-6 fill-[#0077b5] group-hover:fill-white transition-colors duration-300"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>

        <a
          href="#"
          target="_blank"
          class="group flex items-center justify-center w-14 h-14 bg-white rounded-full shadow-lg transition-all duration-300 hover:bg-gradient-to-tr hover:from-yellow-400 hover:via-red-500 hover:to-purple-500 hover:-translate-y-1"
        >
          <svg
            class="w-7 h-7 fill-[#E1306C] group-hover:fill-white transition-colors duration-300"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
      </div>
      <div class="flex gap-4">
        <a
          href="#projects"
          class="px-8 py-3 bg-cyan-electric text-black-deep font-bold rounded-full hover:bg-white transition-colors duration-300"
        >
          Ver Proyectos
        </a>
        <a
          href="/blog"
          class="px-8 py-3 border border-orange-fire text-orange-fire font-bold rounded-full hover:bg-orange-fire hover:text-white transition-colors duration-300"
        >
          Leer Blog
        </a>
      </div>
    </section>

    <!-- About Section -->
    <section class="py-20 px-8 bg-gray-leather/30">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-white">Sobre Mí</h2>
        <p class="text-gray-300 text-lg leading-relaxed mb-8">
          Soy estudiante de la carrera Ingeniería de Sistemas Computacionales,
          me considero una persona que le gusta aprender de manera autodidacta,
          me gusta el trabajo en equipo de una forma interactiva, siempre
          abierto a aprender alguna actividad nueva.
        </p>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="py-20 px-8 bg-black-deep relative">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center text-white">
          Tecnologías & Skills
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Languages -->
          <SkillCategory title="Lenguajes">
            <SkillItem
              name="JavaScript"
              iconClass="devicon-javascript-plain"
              color="#F7DF1E"
            />
            <SkillItem
              name="Python"
              iconClass="devicon-python-plain"
              color="#3776AB"
            />
            <SkillItem
              name="PHP"
              iconClass="devicon-php-plain"
              color="#777BB4"
            />
            <SkillItem
              name="Java"
              iconClass="devicon-java-plain"
              color="#007396"
            />
            <SkillItem
              name="SQL"
              iconClass="devicon-mysql-plain"
              color="#4479A1"
            />
          </SkillCategory>

          <!-- Libraries/Frameworks -->
          <SkillCategory title="Librerías & Frameworks">
            <SkillItem
              name="Angular"
              iconClass="devicon-angularjs-plain"
              color="#DD0031"
            />
            <SkillItem
              name="React"
              iconClass="devicon-react-original"
              color="#61DAFB"
            />
            <SkillItem
              name="Astro"
              iconClass="devicon-astro-plain"
              color="#BC52EE"
            />
            <SkillItem
              name="Tailwind"
              iconClass="devicon-tailwindcss-plain"
              color="#06B6D4"
            />
          </SkillCategory>

          <!-- Tools -->
          <SkillCategory title="Herramientas">
            <SkillItem
              name="Git"
              iconClass="devicon-git-plain"
              color="#F05032"
            />
            <SkillItem
              name="Docker"
              iconClass="devicon-docker-plain"
              color="#2496ED"
            />
            <SkillItem
              name="GitHub"
              iconClass="devicon-github-original"
              color="#ffffff"
            />
            <SkillItem
              name="VS Code"
              iconClass="devicon-vscode-plain"
              color="#007ACC"
            />
          </SkillCategory>

          <!-- Extra -->
          <SkillCategory title="Extra">
            <!-- Using generic icons/classes for concepts usually represented by other symbols -->
            <!-- Automation (Robot) -->
            <div
              class="flex flex-col items-center gap-2 group p-4 rounded-lg hover:bg-white/5 transition-all duration-300"
            >
              <span class="text-4xl">🤖</span>
              <span
                class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors text-center"
                >Automation</span
              >
            </div>
            <!-- AI (Brain) -->
            <div
              class="flex flex-col items-center gap-2 group p-4 rounded-lg hover:bg-white/5 transition-all duration-300"
            >
              <span class="text-4xl">🧠</span>
              <span
                class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors text-center"
                >AI</span
              >
            </div>
            <!-- Agile (Cycle) -->
            <div
              class="flex flex-col items-center gap-2 group p-4 rounded-lg hover:bg-white/5 transition-all duration-300"
            >
              <span class="text-4xl">🔄</span>
              <span
                class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors text-center"
                >Agile</span
              >
            </div>
            <!-- n8n (Custom logic/workflow) -->
            <div
              class="flex flex-col items-center gap-2 group p-4 rounded-lg hover:bg-white/5 transition-all duration-300"
            >
              <span class="text-4xl text-[#FF6D5A] font-bold">n8n</span>
              <span
                class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors text-center"
                >n8n</span
              >
            </div>
          </SkillCategory>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="py-20 bg-gray-leather/30 overflow-hidden">
      <div class="max-w-[100vw]">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center text-white">
          Proyectos Realizados
        </h2>
        <ProjectSlider projects={projects} />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
