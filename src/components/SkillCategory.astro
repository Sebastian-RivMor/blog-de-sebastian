---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<div
    class="bg-gray-leather/30 p-6 rounded-2xl border border-white/5 hover:border-cyan-electric/30 transition-colors"
>
    <h3
        class="text-xl font-bold mb-6 text-cyan-electric border-b border-white/10 pb-2"
    >
        {title}
    </h3>
    <div class="grid grid-cols-3 sm:grid-cols-4 gap-4">
        <slot />
    </div>
</div>
