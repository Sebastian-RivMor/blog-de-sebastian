---
interface Props {
    title: string;
}

const { title } = Astro.props;
---

<div
    class="bg-bg-alt p-6 rounded-2xl border border-black/5 hover:border-brand-primary/30 hover:shadow-lg transition-all duration-300"
>
    <h3
        class="text-xl font-bold mb-6 text-brand-primary border-b border-black/10 pb-2"
    >
        {title}
    </h3>
    <div class="grid grid-cols-3 sm:grid-cols-4 gap-4">
        <slot />
    </div>
</div>
