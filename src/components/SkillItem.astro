---
interface Props {
    name: string;
    iconClass: string;
    color?: string;
}

const { name, iconClass, color } = Astro.props;
---

<div
    class="flex flex-col items-center gap-2 group p-4 rounded-lg hover:bg-white/5 transition-all duration-300"
>
    <i
        class={`${iconClass} text-4xl group-hover:scale-110 transition-transform duration-300`}
        style={color ? `color: ${color}` : ""}></i>
    <span
        class="text-sm font-medium text-gray-400 group-hover:text-white transition-colors text-center"
        >{name}</span
    >
</div>
